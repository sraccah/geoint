# PostgreSQL
POSTGRES_DB=geoint
POSTGRES_USER=geoint
POSTGRES_PASSWORD=geoint_secret

# Redis
REDIS_URL=redis://redis:6366

# OpenSky Network — OAuth2 client credentials (higher rate limits than anonymous)
# Register at https://opensky-network.org/
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Windy Webcams API key — fetches 500+ live webcams dynamically
# Get free key at https://api.windy.com (Webcams section)
WINDY_API_KEY=

# Windy Map Forecast API key — weather overlays (wind, rain, temp, etc.)
# Get free key at https://api.windy.com (Map Forecast section)
WINDY_FORECAST_KEY=

# CORS — set to your production domain
CORS_ORIGIN=http://localhost:3666

# Flight data poll interval in ms (minimum 5000 for authenticated, 10000 anonymous)
FLIGHT_POLL_INTERVAL=5000

# Webcams.travel RapidAPI key (optional)
WEBCAMS_TRAVEL_KEY=

# Thunderforest API key — Transport map style
# Get your own free key at https://www.thunderforest.com/
THUNDERFOREST_KEY=
